


venv/                       # Mon environnement virtuel
*.pyc                       # Fichiers Python compilés
__pycache__/                # Dossiers de cache
.env                        # LES ID de Connexion (crucial pour PostgreSQL plus tard)
rapport_excel/*.xlsx        # Les rapports Excel générés
logs/*.log                  # Les fichiers de logs locaux
data/raw/*.csv              # Les données brutes après extraction 
data/processed/*.csv        # Les fichiers brutes propres
tests/*.csv                 # Les fichiers des testes unitaires
power_bi/data/*.xlsx        # Power BI data
lancer_pipeline.bat         # Cron Job local pour Orchestré le tout 